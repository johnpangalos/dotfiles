# Auto detect text files and normalize line endings
* text=auto eol=lf

# Shell
*.sh text eol=lf
*.zshrc text eol=lf

# Lua
*.lua text eol=lf

# Config files
*.toml text eol=lf
*.json text eol=lf
*.conf text eol=lf
*.editorconfig text eol=lf

# Templates
*.tmpl text eol=lf

# Swift
*.swift text eol=lf

# Markdown
*.md text eol=lf

# Spell files
*.spl binary

# Brewfiles
Brewfile text eol=lf
Brewfile.* text eol=lf
