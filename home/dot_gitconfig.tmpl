[pull]
	rebase = true
[user]
	name = {{ .name }}
	email = {{ .email }}
{{ if not .work }}	signingkey = 3B69CAE17ABCF4AD
{{ end -}}[push]
	autoSetupRemote = true
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
[merge]
	conflictstyle = zdiff3
[diff]
	colorMoved = default
